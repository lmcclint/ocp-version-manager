#!/usr/bin/env bash
#
# ocp - OpenShift installer/client version manager
#
# Downloads versioned openshift-install / oc / kubectl binaries from the
# public OpenShift mirror into ~/.local/bin, letting multiple OCP versions
# coexist. A 'use' command swaps the bare-named symlinks between versions.
#
# Subcommands:
#   ocp get <version|channel>   Download + verify + install a version
#   ocp use <version>           Point openshift-install/oc/kubectl at a version
#   ocp list                    List installed versions (* = active)
#   ocp list-versions [X.Y]     List versions available on the mirror
#   ocp list-channels <X.Y>     List a minor's channels and their versions
#   ocp remove <version>        Remove an installed version's binaries
#
set -euo pipefail

# ---- configuration ---------------------------------------------------------

VERSION="0.3.2"

# Despite the "x86_64" in the path, this is the mirror's cross-platform client
# directory: each version dir holds the linux, linux-arm64, mac and mac-arm64
# tarballs (the arm64 binaries are served from here, not the sibling arm64/
# tree), so detect_platform's tokens all resolve against this one URL. The
# ppc64le/s390x clients live here too but their installers do not, so those
# arches aren't fully supported. Override OCP_BASE_URL to point at another tree.
BASE_URL="${OCP_BASE_URL:-https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp}"
BIN_DIR="${OCP_BIN_DIR:-$HOME/.local/bin}"

# Where 'ocp update' pulls a fresh copy of this script from. Override for forks.
UPDATE_URL="${OCP_UPDATE_URL:-https://raw.githubusercontent.com/lmcclint/ocp-version-manager/main/ocp}"

# Tarball names are version-qualified (e.g. openshift-install-linux-4.14.1.tar.gz).
# These versioned names are listed in sha256sum.txt for both exact-version and
# channel directories, whereas the generic names are not present in exact dirs.

# Components ocp manages. The first three are "core": always expected, and
# 'use' warns + unsets the bare link when one is missing. oc-mirror is optional
# (Linux-only, opt-in): linked when present, silently skipped when absent.
CORE_COMPONENTS=(openshift-install oc kubectl)
OPTIONAL_COMPONENTS=(oc-mirror)
ALL_COMPONENTS=("${CORE_COMPONENTS[@]}" "${OPTIONAL_COMPONENTS[@]}")

# ---- helpers ---------------------------------------------------------------

err()  { printf 'error: %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }
info() { printf '%s\n' "$*" >&2; }

require() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

# Mirror platform token for this host (linux, linux-arm64, mac, mac-arm64).
# Override with OCP_PLATFORM, e.g. OCP_PLATFORM=mac-arm64.
detect_platform() {
  [ -n "${OCP_PLATFORM:-}" ] && { printf '%s\n' "$OCP_PLATFORM"; return; }
  local os arch
  os="$(uname -s)"
  arch="$(uname -m)"
  case "$os" in
    Linux)  os="linux" ;;
    Darwin) os="mac" ;;
    *) die "unsupported OS '$os' (set OCP_PLATFORM to override)" ;;
  esac
  case "$arch" in
    x86_64|amd64)  arch="" ;;        # x86_64 token is just "linux"/"mac"
    arm64|aarch64) arch="-arm64" ;;
    *) die "unsupported architecture '$arch' (set OCP_PLATFORM to override)" ;;
  esac
  printf '%s%s\n' "$os" "$arch"
}

# Portable SHA-256: GNU sha256sum or BSD/macOS 'shasum -a 256'. Echoes the hash.
sha256_of() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    die "need 'sha256sum' or 'shasum' to verify downloads"
  fi
}

# Portable version sort: GNU 'sort -V' if available, else plain sort.
vsort() {
  if printf '1\n2\n' | sort -V >/dev/null 2>&1; then sort -V; else sort; fi
}

# Single workdir, cleaned up once on exit (avoids per-function RETURN traps).
WORKDIR=""
# Note: this runs as the EXIT trap, so its final status becomes the script's
# exit code; the trailing ':' keeps a no-op cleanup from forcing a nonzero exit.
cleanup() { [ -n "$WORKDIR" ] && rm -rf "$WORKDIR"; :; }
trap cleanup EXIT

check_path() {
  case ":$PATH:" in
    *":$BIN_DIR:"*) ;;
    *) info "warning: $BIN_DIR is not on your \$PATH; add it to use these binaries" ;;
  esac
}

usage() {
  cat <<EOF
ocp - OpenShift installer/client version manager

Usage:
  ocp get [--cli-only|--installer-only] [--use] <version|channel>
                              Download, verify and install a version.
                              --cli-only       only oc + kubectl
                              --installer-only only openshift-install
                              --use            activate it afterwards
  ocp use <version>           Activate a version (swap symlinks)
  ocp list                    List installed versions (* = active)
  ocp list-versions [X.Y]     List versions available on the mirror
  ocp list-channels <X.Y>     List a minor's channels and the version each points to
  ocp remove <version>        Remove an installed version
  ocp update                  Update ocp itself to the latest version
  ocp --version               Print the ocp version

Examples:
  ocp get 4.14.1
  ocp get stable-4.15
  ocp get --cli-only 4.14.1
  ocp get --installer-only stable-4.15
  ocp get --use 4.14.1
  ocp use 4.14.1
  ocp list-versions 4.14
  ocp list-channels 4.14

Binaries are installed to: $BIN_DIR

Environment:
  OCP_BIN_DIR    install directory (default ~/.local/bin)
  OCP_PLATFORM   force platform: linux | linux-arm64 | mac | mac-arm64
                 (default: auto-detected from uname)
  OCP_INSECURE   set to 1 to continue past a checksum mismatch
  OCP_BASE_URL   mirror clients dir (default: the cross-platform x86_64 tree,
                 which also serves the arm64 + mac binaries)
  OCP_UPDATE_URL source URL for 'ocp update' (default: GitHub raw, main)
EOF
}

# Resolve a version-or-channel argument to a concrete version string by
# reading <arg>/release.txt from the mirror. Echoes the concrete version.
resolve_version() {
  local ref="$1" release name
  release="$(curl -fsSL "$BASE_URL/$ref/release.txt" 2>/dev/null)" \
    || die "could not find '$ref' on the mirror ($BASE_URL/$ref/)"
  name="$(printf '%s\n' "$release" | sed -n 's/^Name:[[:space:]]*//p' | head -n1)"
  [ -n "$name" ] || die "could not parse a version from $ref/release.txt"
  printf '%s\n' "$name"
}

# Verify a file against a line in sha256sum.txt. Args: <sumfile> <tarball-name> <file>
# A missing checksum line is fatal (wrong filename). A hash mismatch returns 1
# so the caller can decide (the mirror's Apple-Silicon checksums are unreliable).
verify_checksum() {
  local sumfile="$1" tarball="$2" file="$3" expected actual
  expected="$(grep -E "[[:space:]]${tarball}\$" "$sumfile" | awk '{print $1}' | head -n1)"
  [ -n "$expected" ] || die "no checksum for $tarball in sha256sum.txt"
  actual="$(sha256_of "$file")"
  if [ "$expected" != "$actual" ]; then
    info "checksum mismatch for $tarball (expected $expected, got $actual)"
    return 1
  fi
}

# ---- subcommands -----------------------------------------------------------

cmd_get() {
  # "cli" = the client tarball (oc + kubectl); "installer" = openshift-install.
  local ref="" want_cli=1 want_installer=1 do_use=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --cli-only)       want_installer=0 ;;
      --installer-only) want_cli=0 ;;
      --use)            do_use=1 ;;
      -*) die "unknown flag: $1 (see 'ocp --help')" ;;
      *)  [ -z "$ref" ] || die "unexpected argument: $1"; ref="$1" ;;
    esac
    shift
  done
  [ -n "$ref" ] || die "usage: ocp get [--cli-only|--installer-only] <version|channel>"
  [ "$want_cli" = 1 ] || [ "$want_installer" = 1 ] \
    || die "--cli-only and --installer-only are mutually exclusive"
  require curl; require tar

  local platform version
  platform="$(detect_platform)"
  version="$(resolve_version "$ref")"
  info "Resolved '$ref' -> $version ($platform)"

  # Only fetch components that are both requested and not already installed,
  # so a repeated 'get' (or one that completes a partial install) skips work.
  local need_installer=0 need_client=0
  [ "$want_installer" = 1 ] && [ ! -x "$BIN_DIR/openshift-install-$version" ] && need_installer=1
  [ "$want_cli" = 1 ]       && [ ! -x "$BIN_DIR/oc-$version" ]                && need_client=1

  if [ "$need_installer" = 0 ] && [ "$need_client" = 0 ]; then
    info "$version already installed (requested components present)"
    if [ "$do_use" = 1 ]; then cmd_use "$version"; else check_path; fi
    return 0
  fi

  local install_tarball="openshift-install-$platform-$version.tar.gz"
  local client_tarball="openshift-client-$platform-$version.tar.gz"

  # Tarballs to fetch this run (never empty: we returned early if nothing needed).
  local tarballs=()
  [ "$need_installer" = 1 ] && tarballs+=("$install_tarball")
  [ "$need_client" = 1 ]    && tarballs+=("$client_tarball")

  local tmp
  WORKDIR="$(mktemp -d)"
  tmp="$WORKDIR"

  info "Downloading sha256sum.txt ..."
  curl -fsSL "$BASE_URL/$ref/sha256sum.txt" -o "$tmp/sha256sum.txt" \
    || die "failed to download sha256sum.txt"

  local t
  for t in "${tarballs[@]}"; do
    info "Downloading $t ..."
    curl -fSL --progress-bar "$BASE_URL/$ref/$t" -o "$tmp/$t" \
      || die "failed to download $t"
  done

  info "Verifying checksums ..."
  for t in "${tarballs[@]}"; do
    if ! verify_checksum "$tmp/sha256sum.txt" "$t" "$tmp/$t"; then
      if [ "$platform" = "mac-arm64" ]; then
        info "  note: Apple Silicon binaries are re-signed/notarized after the mirror"
        info "  publishes sha256sum.txt, so this mismatch is expected upstream; continuing."
      elif [ "${OCP_INSECURE:-}" = "1" ]; then
        info "  OCP_INSECURE=1 set; continuing despite mismatch."
      else
        die "checksum verification failed for $t (set OCP_INSECURE=1 to override)"
      fi
    fi
  done

  info "Extracting ..."
  mkdir -p "$BIN_DIR"
  info "Installed:"
  if [ "$need_installer" = 1 ]; then
    tar -xzf "$tmp/$install_tarball" -C "$tmp" openshift-install
    install -m 0755 "$tmp/openshift-install" "$BIN_DIR/openshift-install-$version"
    info "  $BIN_DIR/openshift-install-$version"
  fi
  if [ "$need_client" = 1 ]; then
    tar -xzf "$tmp/$client_tarball" -C "$tmp" oc kubectl
    install -m 0755 "$tmp/oc"      "$BIN_DIR/oc-$version"
    install -m 0755 "$tmp/kubectl" "$BIN_DIR/kubectl-$version"
    info "  $BIN_DIR/oc-$version"
    info "  $BIN_DIR/kubectl-$version"
  fi
  if [ "$do_use" = 1 ]; then
    cmd_use "$version"
  else
    info "Run 'ocp use $version' to activate it."
    check_path
  fi
}

# Echo the active version, read from the first bare symlink that exists.
# Falls back oc/kubectl so a cli-only active version is still detected.
active_version() {
  local bare link target
  for bare in "${ALL_COMPONENTS[@]}"; do
    link="$BIN_DIR/$bare"
    [ -L "$link" ] || continue
    target="$(readlink "$link")"
    printf '%s\n' "${target##*$bare-}"
    return 0
  done
}

# Echo the components installed for a version as a comma-joined list
# (e.g. "installer, oc, kubectl"), or nothing if none are installed.
installed_components() {
  local version="$1" present=""
  [ -x "$BIN_DIR/openshift-install-$version" ] && present="${present:+$present, }installer"
  [ -x "$BIN_DIR/oc-$version" ]                && present="${present:+$present, }oc"
  [ -x "$BIN_DIR/kubectl-$version" ]           && present="${present:+$present, }kubectl"
  [ -x "$BIN_DIR/oc-mirror-$version" ]         && present="${present:+$present, }oc-mirror"
  printf '%s' "$present"
}

cmd_use() {
  local version="${1:-}"
  [ -n "$version" ] || die "usage: ocp use <version>"

  # Tolerate partial installs: require at least one component, not all three.
  local bare any=0
  for bare in openshift-install oc kubectl; do
    [ -x "$BIN_DIR/$bare-$version" ] && any=1
  done
  [ "$any" = 1 ] || die "$version not installed; run 'ocp get $version' first"

  # Relative links, contained to a subshell so the cd doesn't leak.
  ( cd "$BIN_DIR" || die "cannot cd to $BIN_DIR"
    for bare in openshift-install oc kubectl; do
      rm -f "$bare"   # portable replace (BSD ln lacks -n)
      if [ -x "$bare-$version" ]; then
        ln -s "$bare-$version" "$bare"
      else
        info "warning: $bare not installed for $version; '$bare' unset"
      fi
    done )
  info "Now using OCP $version"
  check_path
}

cmd_list() {
  local active comp f
  active="$(active_version)"

  # Union versions across all components so cli-only / installer-only
  # installs are listed too (not just those with openshift-install). Collect
  # the real files too, for the total-size summary.
  shopt -s nullglob
  local versions=() files=()
  for comp in "${ALL_COMPONENTS[@]}"; do
    for f in "$BIN_DIR/$comp"-*; do
      [ -L "$f" ] && continue   # skip the bare symlink if it matched
      # 'oc-*' also matches 'oc-mirror-*'; oc-mirror is gathered on its own pass.
      [ "$comp" = oc ] && case "${f##*/}" in oc-mirror-*) continue ;; esac
      versions+=("${f##*/$comp-}")
      files+=("$f")
    done
  done
  shopt -u nullglob

  if [ "${#versions[@]}" -eq 0 ]; then
    info "no versions installed; try 'ocp get <version>'"
    return 0
  fi

  # Unique, version-sorted; annotate each with the components present.
  local version marker
  printf '%s\n' "${versions[@]}" | vsort | uniq | while IFS= read -r version; do
    [ "$version" = "$active" ] && marker='*' || marker=' '
    printf '%s %s  (%s)\n' "$marker" "$version" "$(installed_components "$version")"
  done

  # Total disk consumed by the installed binaries (du measures actual usage).
  local total
  total="$(du -ch "${files[@]}" 2>/dev/null | tail -n1 | awk '{print $1}')" || true
  [ -n "$total" ] && printf 'Total: %s\n' "$total"
}

cmd_list_versions() {
  require curl
  local filter="${1:-}" url="$BASE_URL/" pat=""
  if [ -n "$filter" ]; then
    # Reduce a channel-style filter (stable-4.20, fast-4.16, ...) to its
    # version part so 'list-versions stable-4.20' lists the 4.20 line, the same
    # way channels are accepted by 'get'/'use'.
    filter="$(printf '%s\n' "$filter" | sed -E 's/^[A-Za-z]+-//')"
    # Anchor at a version-segment boundary (next char is '.' or end of line)
    # so '4.2' doesn't match '4.20', while a full version or channel still does.
    pat="^${filter//./\\.}(\\.|\$)"
  fi

  local listing
  listing="$(curl -fsSL "$url")" || die "failed to list $url"
  listing="$(printf '%s\n' "$listing" \
    | grep -oE 'href="[^"]+/"' \
    | sed -E 's/href="([^"]+)\/"/\1/' \
    | grep -vE '^\.')" || true

  local results
  if [ -n "$pat" ]; then
    results="$(printf '%s\n' "$listing" | grep -E "$pat" | vsort | uniq)" || true
  else
    results="$(printf '%s\n' "$listing" | vsort | uniq)" || true
  fi

  if [ -z "$results" ]; then
    info "no versions on the mirror match '${1:-}'"
    return 0
  fi

  # Annotate any version already installed locally with its components.
  local version comps
  printf '%s\n' "$results" | while IFS= read -r version; do
    comps="$(installed_components "$version")"
    if [ -n "$comps" ]; then
      printf '%s  (installed: %s)\n' "$version" "$comps"
    else
      printf '%s\n' "$version"
    fi
  done
}

# List the release channels for a minor (candidate/fast/stable/latest-X.Y)
# alongside the concrete version each currently points to.
cmd_list_channels() {
  require curl
  local filter="${1:-}"
  [ -n "$filter" ] || die "usage: ocp list-channels <X.Y>  (e.g. ocp list-channels 4.20)"
  # Accept 'stable-4.20' too by reducing it to its X.Y part.
  filter="$(printf '%s\n' "$filter" | sed -E 's/^[A-Za-z]+-//')"

  local listing channels
  listing="$(curl -fsSL "$BASE_URL/")" || die "failed to list $BASE_URL/"
  # Channel dirs start with a letter; keep those ending at the requested X.Y
  # (preceded by '-' or line start) so '4.2' doesn't match '4.20'.
  channels="$(printf '%s\n' "$listing" \
    | grep -oE 'href="[^"]+/"' \
    | sed -E 's/href="([^"]+)\/"/\1/' \
    | grep -E '^[A-Za-z]' \
    | grep -E "(^|-)${filter//./\\.}\$" \
    | vsort | uniq)" || true

  if [ -z "$channels" ]; then
    info "no channels on the mirror match '${1:-}'"
    return 0
  fi

  local ch ver comps
  while IFS= read -r ch; do
    ver="$(curl -fsSL "$BASE_URL/$ch/release.txt" 2>/dev/null \
      | sed -n 's/^Name:[[:space:]]*//p' | head -n1)" || true
    comps=""
    [ -n "$ver" ] && comps="$(installed_components "$ver")"
    if [ -n "$comps" ]; then
      printf '%-16s %s  (installed: %s)\n' "$ch" "$ver" "$comps"
    else
      printf '%-16s %s\n' "$ch" "${ver:-(unresolved)}"
    fi
  done <<EOF
$channels
EOF
}

cmd_remove() {
  local version="${1:-}"
  [ -n "$version" ] || die "usage: ocp remove <version>"
  local active removed=0
  active="$(active_version)"

  if [ "$version" = "$active" ]; then
    info "warning: $version is the active version; symlinks will dangle until you 'ocp use' another"
  fi

  for bare in "${ALL_COMPONENTS[@]}"; do
    if [ -e "$BIN_DIR/$bare-$version" ]; then
      rm -f "$BIN_DIR/$bare-$version"
      removed=1
    fi
  done
  [ "$removed" = 1 ] || die "$version is not installed"
  info "Removed OCP $version"
}

# Absolute path of this running script, resolving a PATH lookup and symlinks.
self_path() {
  local src="$0" dir target
  case "$src" in
    */*) ;;
    *) src="$(command -v -- "$src" 2>/dev/null || true)"
       [ -n "$src" ] || die "cannot locate the running script ($0)" ;;
  esac
  while [ -L "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    target="$(readlink "$src")"
    case "$target" in
      /*) src="$target" ;;
      *)  src="$dir/$target" ;;
    esac
  done
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$src")"
}

# Replace this script with the latest copy from UPDATE_URL.
cmd_update() {
  require curl
  local self dir tmp staging newver
  self="$(self_path)"
  dir="$(dirname "$self")"
  [ -w "$self" ] || die "$self is not writable (re-run with the right permissions)"
  [ -w "$dir" ]  || die "$dir is not writable (cannot stage the update)"

  WORKDIR="$(mktemp -d)"
  tmp="$WORKDIR/ocp"
  info "Downloading latest ocp from $UPDATE_URL ..."
  curl -fsSL "$UPDATE_URL" -o "$tmp" || die "failed to download update"

  # Refuse to install anything that isn't a valid shell script (guards against
  # an HTML error page or a truncated download bricking the tool).
  head -n1 "$tmp" | grep -qE '^#!.*(bash|sh)' || die "download is not a shell script; aborting"
  bash -n "$tmp" || die "downloaded script failed its syntax check; aborting"

  newver="$(sed -n 's/^VERSION="\([^"]*\)".*/\1/p' "$tmp" | head -n1)"
  [ -n "$newver" ] || newver="(unknown)"
  if [ "$newver" = "$VERSION" ]; then
    info "Already up to date (version $VERSION)"
    return 0
  fi

  # Atomic replace: stage next to the target, then rename over it.
  staging="$(mktemp "$dir/.ocp.XXXXXX")" || die "cannot create temp file in $dir"
  if ! cp "$tmp" "$staging"; then rm -f "$staging"; die "failed to stage update"; fi
  chmod 0755 "$staging"
  mv -f "$staging" "$self" || { rm -f "$staging"; die "failed to install update to $self"; }
  info "Updated ocp: $VERSION -> $newver"
}

# ---- dispatch --------------------------------------------------------------

main() {
  local sub="${1:-}"
  [ "$#" -gt 0 ] && shift || true
  case "$sub" in
    get)         cmd_get "$@" ;;
    use)         cmd_use "$@" ;;
    list)        cmd_list "$@" ;;
    list-versions|list-remote) cmd_list_versions "$@" ;;
    list-channels) cmd_list_channels "$@" ;;
    remove|rm)   cmd_remove "$@" ;;
    update|--update) cmd_update "$@" ;;
    --version|-V|version) printf 'ocp %s\n' "$VERSION" ;;
    ""|-h|--help|help) usage ;;
    *) err "unknown command: $sub"; usage; exit 1 ;;
  esac
}

main "$@"
