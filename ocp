#!/usr/bin/env bash
#
# ocp - OpenShift installer/client version manager
#
# Downloads versioned openshift-install / oc / kubectl binaries from the
# public OpenShift mirror into ~/.local/bin, letting multiple OCP versions
# coexist. A 'use' command swaps the bare-named symlinks between versions.
#
# Subcommands:
#   ocp get <version|channel>   Download + verify + install a version
#   ocp use <version>           Point openshift-install/oc/kubectl at a version
#   ocp list                    List installed versions (* = active)
#   ocp list-remote [X.Y]       List versions available on the mirror
#   ocp remove <version>        Remove an installed version's binaries
#
set -euo pipefail

# ---- configuration ---------------------------------------------------------

BASE_URL="https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp"
BIN_DIR="${OCP_BIN_DIR:-$HOME/.local/bin}"

# Tarball names are version-qualified (e.g. openshift-install-linux-4.14.1.tar.gz).
# These versioned names are listed in sha256sum.txt for both exact-version and
# channel directories, whereas the generic names are not present in exact dirs.

# ---- helpers ---------------------------------------------------------------

err()  { printf 'error: %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }
info() { printf '%s\n' "$*" >&2; }

require() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

# Mirror platform token for this host (linux, linux-arm64, mac, mac-arm64).
# Override with OCP_PLATFORM, e.g. OCP_PLATFORM=mac-arm64.
detect_platform() {
  [ -n "${OCP_PLATFORM:-}" ] && { printf '%s\n' "$OCP_PLATFORM"; return; }
  local os arch
  os="$(uname -s)"
  arch="$(uname -m)"
  case "$os" in
    Linux)  os="linux" ;;
    Darwin) os="mac" ;;
    *) die "unsupported OS '$os' (set OCP_PLATFORM to override)" ;;
  esac
  case "$arch" in
    x86_64|amd64)  arch="" ;;        # x86_64 token is just "linux"/"mac"
    arm64|aarch64) arch="-arm64" ;;
    *) die "unsupported architecture '$arch' (set OCP_PLATFORM to override)" ;;
  esac
  printf '%s%s\n' "$os" "$arch"
}

# Portable SHA-256: GNU sha256sum or BSD/macOS 'shasum -a 256'. Echoes the hash.
sha256_of() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    die "need 'sha256sum' or 'shasum' to verify downloads"
  fi
}

# Portable version sort: GNU 'sort -V' if available, else plain sort.
vsort() {
  if printf '1\n2\n' | sort -V >/dev/null 2>&1; then sort -V; else sort; fi
}

# Single workdir, cleaned up once on exit (avoids per-function RETURN traps).
WORKDIR=""
cleanup() { [ -n "$WORKDIR" ] && rm -rf "$WORKDIR"; }
trap cleanup EXIT

check_path() {
  case ":$PATH:" in
    *":$BIN_DIR:"*) ;;
    *) info "warning: $BIN_DIR is not on your \$PATH; add it to use these binaries" ;;
  esac
}

usage() {
  cat <<EOF
ocp - OpenShift installer/client version manager

Usage:
  ocp get [--cli-only|--installer-only] <version|channel>
                              Download, verify and install a version.
                              --cli-only       only oc + kubectl
                              --installer-only only openshift-install
  ocp use <version>           Activate a version (swap symlinks)
  ocp list                    List installed versions (* = active)
  ocp list-remote [X.Y]       List versions available on the mirror
  ocp remove <version>        Remove an installed version

Examples:
  ocp get 4.14.1
  ocp get stable-4.15
  ocp get --cli-only 4.14.1
  ocp get --installer-only stable-4.15
  ocp use 4.14.1
  ocp list-remote 4.14

Binaries are installed to: $BIN_DIR

Environment:
  OCP_BIN_DIR    install directory (default ~/.local/bin)
  OCP_PLATFORM   force platform: linux | linux-arm64 | mac | mac-arm64
                 (default: auto-detected from uname)
  OCP_INSECURE   set to 1 to continue past a checksum mismatch
EOF
}

# Resolve a version-or-channel argument to a concrete version string by
# reading <arg>/release.txt from the mirror. Echoes the concrete version.
resolve_version() {
  local ref="$1" release name
  release="$(curl -fsSL "$BASE_URL/$ref/release.txt" 2>/dev/null)" \
    || die "could not find '$ref' on the mirror ($BASE_URL/$ref/)"
  name="$(printf '%s\n' "$release" | sed -n 's/^Name:[[:space:]]*//p' | head -n1)"
  [ -n "$name" ] || die "could not parse a version from $ref/release.txt"
  printf '%s\n' "$name"
}

# Verify a file against a line in sha256sum.txt. Args: <sumfile> <tarball-name> <file>
# A missing checksum line is fatal (wrong filename). A hash mismatch returns 1
# so the caller can decide (the mirror's Apple-Silicon checksums are unreliable).
verify_checksum() {
  local sumfile="$1" tarball="$2" file="$3" expected actual
  expected="$(grep -E "[[:space:]]${tarball}\$" "$sumfile" | awk '{print $1}' | head -n1)"
  [ -n "$expected" ] || die "no checksum for $tarball in sha256sum.txt"
  actual="$(sha256_of "$file")"
  if [ "$expected" != "$actual" ]; then
    info "checksum mismatch for $tarball (expected $expected, got $actual)"
    return 1
  fi
}

# ---- subcommands -----------------------------------------------------------

cmd_get() {
  # "cli" = the client tarball (oc + kubectl); "installer" = openshift-install.
  local ref="" want_cli=1 want_installer=1
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --cli-only)       want_installer=0 ;;
      --installer-only) want_cli=0 ;;
      -*) die "unknown flag: $1 (see 'ocp --help')" ;;
      *)  [ -z "$ref" ] || die "unexpected argument: $1"; ref="$1" ;;
    esac
    shift
  done
  [ -n "$ref" ] || die "usage: ocp get [--cli-only|--installer-only] <version|channel>"
  [ "$want_cli" = 1 ] || [ "$want_installer" = 1 ] \
    || die "--cli-only and --installer-only are mutually exclusive"
  require curl; require tar

  local platform version
  platform="$(detect_platform)"
  version="$(resolve_version "$ref")"
  info "Resolved '$ref' -> $version ($platform)"

  # Only fetch components that are both requested and not already installed,
  # so a repeated 'get' (or one that completes a partial install) skips work.
  local need_installer=0 need_client=0
  [ "$want_installer" = 1 ] && [ ! -x "$BIN_DIR/openshift-install-$version" ] && need_installer=1
  [ "$want_cli" = 1 ]       && [ ! -x "$BIN_DIR/oc-$version" ]                && need_client=1

  if [ "$need_installer" = 0 ] && [ "$need_client" = 0 ]; then
    info "$version already installed (requested components present)"
    check_path
    return 0
  fi

  local install_tarball="openshift-install-$platform-$version.tar.gz"
  local client_tarball="openshift-client-$platform-$version.tar.gz"

  # Tarballs to fetch this run (never empty: we returned early if nothing needed).
  local tarballs=()
  [ "$need_installer" = 1 ] && tarballs+=("$install_tarball")
  [ "$need_client" = 1 ]    && tarballs+=("$client_tarball")

  local tmp
  WORKDIR="$(mktemp -d)"
  tmp="$WORKDIR"

  info "Downloading sha256sum.txt ..."
  curl -fsSL "$BASE_URL/$ref/sha256sum.txt" -o "$tmp/sha256sum.txt" \
    || die "failed to download sha256sum.txt"

  local t
  for t in "${tarballs[@]}"; do
    info "Downloading $t ..."
    curl -fSL --progress-bar "$BASE_URL/$ref/$t" -o "$tmp/$t" \
      || die "failed to download $t"
  done

  info "Verifying checksums ..."
  for t in "${tarballs[@]}"; do
    if ! verify_checksum "$tmp/sha256sum.txt" "$t" "$tmp/$t"; then
      if [ "$platform" = "mac-arm64" ]; then
        info "  note: Apple Silicon binaries are re-signed/notarized after the mirror"
        info "  publishes sha256sum.txt, so this mismatch is expected upstream; continuing."
      elif [ "${OCP_INSECURE:-}" = "1" ]; then
        info "  OCP_INSECURE=1 set; continuing despite mismatch."
      else
        die "checksum verification failed for $t (set OCP_INSECURE=1 to override)"
      fi
    fi
  done

  info "Extracting ..."
  mkdir -p "$BIN_DIR"
  info "Installed:"
  if [ "$need_installer" = 1 ]; then
    tar -xzf "$tmp/$install_tarball" -C "$tmp" openshift-install
    install -m 0755 "$tmp/openshift-install" "$BIN_DIR/openshift-install-$version"
    info "  $BIN_DIR/openshift-install-$version"
  fi
  if [ "$need_client" = 1 ]; then
    tar -xzf "$tmp/$client_tarball" -C "$tmp" oc kubectl
    install -m 0755 "$tmp/oc"      "$BIN_DIR/oc-$version"
    install -m 0755 "$tmp/kubectl" "$BIN_DIR/kubectl-$version"
    info "  $BIN_DIR/oc-$version"
    info "  $BIN_DIR/kubectl-$version"
  fi
  info "Run 'ocp use $version' to activate it."
  check_path
}

# Echo the active version, read from the first bare symlink that exists.
# Falls back oc/kubectl so a cli-only active version is still detected.
active_version() {
  local bare link target
  for bare in openshift-install oc kubectl; do
    link="$BIN_DIR/$bare"
    [ -L "$link" ] || continue
    target="$(readlink "$link")"
    printf '%s\n' "${target##*$bare-}"
    return 0
  done
}

cmd_use() {
  local version="${1:-}"
  [ -n "$version" ] || die "usage: ocp use <version>"

  # Tolerate partial installs: require at least one component, not all three.
  local bare any=0
  for bare in openshift-install oc kubectl; do
    [ -x "$BIN_DIR/$bare-$version" ] && any=1
  done
  [ "$any" = 1 ] || die "$version not installed; run 'ocp get $version' first"

  # Relative links, contained to a subshell so the cd doesn't leak.
  ( cd "$BIN_DIR" || die "cannot cd to $BIN_DIR"
    for bare in openshift-install oc kubectl; do
      rm -f "$bare"   # portable replace (BSD ln lacks -n)
      if [ -x "$bare-$version" ]; then
        ln -s "$bare-$version" "$bare"
      else
        info "warning: $bare not installed for $version; '$bare' unset"
      fi
    done )
  info "Now using OCP $version"
  check_path
}

cmd_list() {
  local active comp f
  active="$(active_version)"

  # Union versions across all components so cli-only / installer-only
  # installs are listed too (not just those with openshift-install).
  shopt -s nullglob
  local versions=()
  for comp in openshift-install oc kubectl; do
    for f in "$BIN_DIR/$comp"-*; do
      [ -L "$f" ] && continue   # skip the bare symlink if it matched
      versions+=("${f##*/$comp-}")
    done
  done
  shopt -u nullglob

  if [ "${#versions[@]}" -eq 0 ]; then
    info "no versions installed; try 'ocp get <version>'"
    return 0
  fi

  # Unique, version-sorted; annotate each with the components present.
  local version marker present
  printf '%s\n' "${versions[@]}" | vsort | uniq | while IFS= read -r version; do
    present=""
    [ -x "$BIN_DIR/openshift-install-$version" ] && present="${present:+$present, }installer"
    [ -x "$BIN_DIR/oc-$version" ]                && present="${present:+$present, }oc"
    [ -x "$BIN_DIR/kubectl-$version" ]           && present="${present:+$present, }kubectl"
    [ "$version" = "$active" ] && marker='*' || marker=' '
    printf '%s %s  (%s)\n' "$marker" "$version" "$present"
  done
}

cmd_list_remote() {
  require curl
  local filter="${1:-}" url="$BASE_URL/"
  curl -fsSL "$url" \
    | grep -oE 'href="[^"]+/"' \
    | sed -E 's/href="([^"]+)\/"/\1/' \
    | grep -vE '^\.' \
    | { if [ -n "$filter" ]; then grep -E "^${filter//./\\.}\." ; else cat; fi; } \
    | vsort \
    | uniq
}

cmd_remove() {
  local version="${1:-}"
  [ -n "$version" ] || die "usage: ocp remove <version>"
  local active removed=0
  active="$(active_version)"

  if [ "$version" = "$active" ]; then
    info "warning: $version is the active version; symlinks will dangle until you 'ocp use' another"
  fi

  for bare in openshift-install oc kubectl; do
    if [ -e "$BIN_DIR/$bare-$version" ]; then
      rm -f "$BIN_DIR/$bare-$version"
      removed=1
    fi
  done
  [ "$removed" = 1 ] || die "$version is not installed"
  info "Removed OCP $version"
}

# ---- dispatch --------------------------------------------------------------

main() {
  local sub="${1:-}"
  [ "$#" -gt 0 ] && shift || true
  case "$sub" in
    get)         cmd_get "$@" ;;
    use)         cmd_use "$@" ;;
    list)        cmd_list "$@" ;;
    list-remote) cmd_list_remote "$@" ;;
    remove|rm)   cmd_remove "$@" ;;
    ""|-h|--help|help) usage ;;
    *) err "unknown command: $sub"; usage; exit 1 ;;
  esac
}

main "$@"
